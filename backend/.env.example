# Environment variables for Vio Backend
# Copy this file to .env and fill in the values

# Database
DATABASE_URL=postgresql://vio:vio@localhost:5432/vio

# Server
PORT=4000
HOST=localhost

# CORS
CORS_ORIGIN=http://localhost:3000

# JWT (generate with: openssl rand -base64 32)
JWT_SECRET=your-secret-key-here

# Environment
NODE_ENV=development

# RPC Logging (verbose | smart | minimal | off)
# verbose  — Full request/response bodies, headers, timing
# smart    — Compact bodies (arrays summarized), headers, timing (default)
# minimal  — Method + status + timing only
# off      — Disabled
RPC_LOG_LEVEL=smart

