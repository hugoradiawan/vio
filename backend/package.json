{
  "name": "vio-backend",
  "version": "0.4.0",
  "description": "Vio Backend - ConnectRPC Server with Git-like Version Control",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "dev:diagnostics": "PERF_DIAGNOSTICS=1 bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir ./dist --target bun",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run src/db/seed.ts",
    "db:seed:stress:small": "bun run src/db/seed.ts --stress-level=small",
    "db:seed:stress:medium": "bun run src/db/seed.ts --stress-level=medium",
    "db:seed:stress:large": "bun run src/db/seed.ts --stress-level=large",
    "proto:generate": "cd ../packages/protos && bunx buf generate",
    "proto:lint": "cd ../packages/protos && bunx buf lint",
    "test": "bun test",
    "lint": "bunx @biomejs/biome lint ./src",
    "format": "bunx @biomejs/biome format --write ./src"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.0.0",
    "@connectrpc/connect": "^2.0.0",
    "@connectrpc/connect-node": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.1",
    "nanoid": "^5.0.9",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.13",
    "@bufbuild/protoc-gen-es": "^2.0.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "^1.2.4",
    "drizzle-kit": "0.31.8",
    "postgres": "^3.4.8",
    "typescript": "^5.7.3"
  },
  "license": "MPL-2.0"
}
